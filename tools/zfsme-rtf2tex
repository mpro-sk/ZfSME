### bash skript slúži na prevod *.rtf súborov zo Zlatý fond Sme do *.tex ###
#  Tento skript používa programy OpenOffice Writer, antiword, iconv, sed   #
#  echo, less a vlna.                                                      #
#  Pre spracovanie *.tex súboru je potrebný  CSTeX (pdfcsplain) a OPmac,   #
#  ako aj súbor makier pre plain/OPmac s názvom ZfSME.tex.                 #
MAINFILEBASE=$(echo "$1" | sed 's/\.[^.]*$//')
HEADER=$2
### echo generuje hlavičku tex súboru (nastavenia a makrá):
if [ "$HEADER" = "0" ] ; then echo %%% "$MAINFILEBASE".tex > $MAINFILEBASE.tex
